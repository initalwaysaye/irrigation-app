# Copy to .env and adjust for your wiring

PORT=3000

# BCM GPIO pin numbers for each zone's relay channel
ZONE1_PIN=17
ZONE2_PIN=27
ZONE3_PIN=22

# Set to true if your relay board activates on HIGH signal (default is active-LOW)
RELAY_ACTIVE_HIGH=false

# Set to true to run without GPIO hardware (for development)
MOCK_GPIO=false

DB_PATH=./data/irrigation.db
